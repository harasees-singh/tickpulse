# Kite Connect app credentials — get these from https://developers.kite.trade
# Copy this file to `.env.local` and fill in your values, then restart `npm run dev`.
# These are used ONLY by the dev auth plugin (server/kiteAuth.ts) and never reach
# the client bundle.

KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here

# The KITE_-prefixed names above also work; either set is accepted.
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here

